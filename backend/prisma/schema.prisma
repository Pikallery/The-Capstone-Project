generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String   @unique
  states    State[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model State {
  id          Int               @id @default(autoincrement())
  code        String            @unique
  name        String
  countryId   Int
  country     Country           @relation(fields: [countryId], references: [id])
  districts   District[]
  userAccess  UserStateAccess[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([countryId])
}

model District {
  id           Int           @id @default(autoincrement())
  code         String
  name         String
  stateId      Int
  state        State         @relation(fields: [stateId], references: [id])
  subDistricts SubDistrict[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([code, stateId])
  @@index([stateId])
}

model SubDistrict {
  id         Int       @id @default(autoincrement())
  code       String
  name       String
  districtId Int
  district   District  @relation(fields: [districtId], references: [id])
  villages   Village[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([code, districtId])
  @@index([districtId])
}

model Village {
  id            Int         @id @default(autoincrement())
  code          String
  name          String
  subDistrictId Int
  subDistrict   SubDistrict @relation(fields: [subDistrictId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([code, subDistrictId])
  @@index([subDistrictId])
  @@index([name])
}

enum PlanType {
  FREE
  PREMIUM
  PRO
  UNLIMITED
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REJECTED
}

model User {
  id           Int               @id @default(autoincrement())
  email        String            @unique
  businessName String
  gstNumber    String?
  phone        String?
  passwordHash String
  planType     PlanType          @default(FREE)
  status       UserStatus        @default(PENDING_APPROVAL)
  isAdmin      Boolean           @default(false)
  notes        String?
  apiKeys      ApiKey[]
  stateAccess  UserStateAccess[]
  logs         ApiLog[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([email])
  @@index([status])
}

model ApiKey {
  id         Int       @id @default(autoincrement())
  name       String
  key        String    @unique
  secretHash String
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  logs       ApiLog[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([key])
  @@index([userId])
}

model UserStateAccess {
  id        Int      @id @default(autoincrement())
  userId    Int
  stateId   Int
  user      User     @relation(fields: [userId], references: [id])
  state     State    @relation(fields: [stateId], references: [id])
  grantedAt DateTime @default(now())

  @@unique([userId, stateId])
  @@index([userId])
}

model ApiLog {
  id           Int      @id @default(autoincrement())
  apiKeyId     Int?
  userId       Int?
  endpoint     String
  method       String   @default("GET")
  statusCode   Int
  responseTime Int
  ipAddress    String?
  userAgent    String?
  query        String?
  apiKey       ApiKey?  @relation(fields: [apiKeyId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([apiKeyId])
  @@index([statusCode])
}
